{
  "name": "bocadoapp",
  "version": "1.0.0",
  "description": "BocadoApp - SaaS Platform for Professional Bakers",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start:frontend": "npm start --workspace=apps/frontend",
    "start:backend": "npm start --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "test:backend": "npm test --workspace=apps/backend",
    "test:frontend": "npm test --workspace=apps/frontend"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "prisma": "^5.10.2"
  }
}
